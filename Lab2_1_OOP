#include <iostream>
#include <vector>
using namespace std;


class TransportUnit {
public:
    virtual double calculateToll(double distance) const = 0;

    virtual ~TransportUnit() {}
};

class Car : public TransportUnit {
public:
    double calculateToll(double distance) const override {
        return distance * 0.1;
    }
};


class Truck : public TransportUnit {
public:
    double calculateToll(double distance) const override {
        return distance * 0.3 + 5.0;
    }
};

int main() {
    setlocale(LC_ALL, "RUS");

    vector<TransportUnit*> transportUnits;

    transportUnits.push_back(new Car());
    transportUnits.push_back(new Truck());
    transportUnits.push_back(new Car());
    transportUnits.push_back(new Truck());

   

    for (size_t i = 0; i < transportUnits.size(); i++) {
        double km = transportUnits[i]->calculateToll(100);
        cout << "cost " << km << "\n";
    }


}
